    "deny": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git reset *)",
      "Bash(git checkout *)",
      "Bash(git restore *)",
      "Bash(git clean *)",
      "Bash(git rebase *)",
      "Bash(git merge *)",
      "Bash(git stash drop *)",
      "Bash(git branch -[dD] *)",
      "Bash(git tag -d *)",
      "Bash(git add *)"
